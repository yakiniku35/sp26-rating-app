# SP26 成果發表會 AI 評分系統環境變數範本
# 複製此檔案為 .env.local，並填入您的實際 API Key

# ---------------------------
# Firebase（用於 Firestore / Auth / Analytics）
# ---------------------------
# Firebase API Key（Firebase Console -> Project settings -> General）
REACT_APP_FIREBASE_API_KEY=your_firebase_api_key_here
# Firebase Auth Domain（通常是 your-project.firebaseapp.com）
REACT_APP_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain_here
# Firebase Project ID
REACT_APP_FIREBASE_PROJECT_ID=your_firebase_project_id_here
# Firebase Storage Bucket
REACT_APP_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket_here
# Firebase Messaging Sender ID
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id_here
# Firebase App ID
REACT_APP_FIREBASE_APP_ID=your_firebase_app_id_here
# Firebase Analytics measurementId（Firebase Console -> Project settings -> General -> measurement ID）
REACT_APP_FIREBASE_MEASUREMENT_ID=G-xxxxxxxxxx

# Gemini API Key（從 Google AI Studio 取得）
REACT_APP_GEMINI_API_KEY=your_gemini_api_key_here

# ---------------------------
# 管理員（Firebase Auth，勿再把密碼寫進 REACT_APP）
# ---------------------------
# 1. Firebase Console → Authentication → Sign-in method → 啟用 Email/Password
# 2. 建立管理員帳號（可於 Authentication 手動新增使用者）
# 3. Firestore → 新增集合 admins → 文件 ID = 該使用者的 UID（內容可為空物件）
# 4. 部署 firestore.rules（專案根目錄）到 Firebase，否則後端仍可能拒絕寫入
