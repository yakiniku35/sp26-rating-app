rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /ratings/{ratingId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.raterUserId
        && (
          isAdmin()
          || ratingId == request.auth.uid + '_' + request.resource.data.presentationKey
        );
      allow update, delete: if isAdmin();
    }

    match /onlineUsers/{userId} {
      allow read: if true;
      allow create, update, delete: if isSignedIn() && request.auth.uid == userId;
    }

    match /rooms/{roomId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 管理員白名單：以文件 ID = Firebase Auth 使用者的 uid（內容可為空物件）
    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
      allow write: if false;
    }
  }
}
