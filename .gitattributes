* text=auto

# Keep common source files as LF in repository
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.md text eol=lf
*.html text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Windows scripts can stay CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
